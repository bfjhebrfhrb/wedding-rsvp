# Пример файла с переменными окружения
# Скопируйте этот файл в .env и заполните своими значениями

# Порт сервера (автоматически устанавливается на Render)
PORT=8000

# Путь к файлу базы данных
DB_FILE=rsvp.db

# Telegram Bot Token (получите у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Chat ID (ваш личный ID или ID группы)
# Для нескольких получателей укажите через запятую: 123456789,987654321
TELEGRAM_CHAT_ID=your_chat_id_here
